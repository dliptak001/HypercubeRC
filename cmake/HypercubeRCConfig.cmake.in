@PACKAGE_INIT@

# OpenMP runtime is needed at link time (library uses OpenMP internally).
# On MinGW, OpenMP is linked via raw -fopenmp flags baked into the exported
# target, so find_package(OpenMP) is neither needed nor reliable.
include(CMakeFindDependencyMacro)
if(NOT MINGW)
    find_dependency(OpenMP)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/HypercubeRCTargets.cmake")

check_required_components(HypercubeRC)
